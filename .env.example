JWT_SECRET=change_this_to_a_long_random_secret_string
PORT=4000

# SQLite database file path. Defaults to server/data/procurement.db when unset (used by
# render.yaml to point at the persistent disk mount in production).
DB_PATH=

# Public URL of the deployed frontend — used for CORS and for links inside emails.
FRONTEND_URL=http://localhost:5173

# Gmail SMTP credentials for sending real emails (vendor invitations, quotation notifications).
# See README.md for how to generate a Gmail App Password.
GMAIL_USER=
GMAIL_APP_PASSWORD=
