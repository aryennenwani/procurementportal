JWT_SECRET=change_this_to_a_long_random_secret_string
PORT=4000

# Public URL of the deployed frontend — used for CORS and for links inside emails.
FRONTEND_URL=http://localhost:5173

# Resend API key for transactional email (vendor invitations, quotation notifications).
RESEND_API_KEY=

# ── SAP S/4HANA integration ──────────────────────────────────────────────────
# When configured, selecting a winning bid automatically creates a purchase order
# in SAP via the standard API_PURCHASEORDER_PROCESS_SRV OData service.
# Leave SAP_BASE_URL empty to run portal-only (POs are still raised internally).
SAP_BASE_URL=
SAP_USERNAME=
SAP_PASSWORD=
# Optional:
SAP_CLIENT=
SAP_COMPANY_CODE=1000
SAP_PURCH_ORG=1000
SAP_PURCH_GROUP=001
SAP_PLANT=1000
